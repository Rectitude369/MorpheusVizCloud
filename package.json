{
  "name": "vizcloud",
  "version": "1.0.0-alpha.1",
  "description": "Production-grade Electron app for Morpheus HVM management",
  "main": "dist/main/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --names \"main,renderer\" --prefix-colors \"magenta,cyan\" \"npm:dev:main\" \"npm:dev:renderer\"",
    "dev:main": "tsx watch src/main/main.ts",
    "dev:renderer": "vite",
    "build": "vite build",
    "typecheck": "npm run typecheck:app && npm run typecheck:main && npm run typecheck:preload",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:main": "tsc -p tsconfig.main.json --noEmit",
    "typecheck:preload": "tsc -p tsconfig.preload.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3,ssh2,cpu-features"
  },
  "keywords": [
    "electron",
    "morpheus",
    "hvm",
    "virtualization",
    "infrastructure",
    "management"
  ],
  "author": "VizCloud Team",
  "license": "MIT",
  "build": {
    "appId": "com.vizcloud.app",
    "productName": "VizCloud",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "build/icon.png"
    },
    "afterPack": "build/after-pack.cjs"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^3.7.0",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ssh2": "^1.15.0",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^32.2.8",
    "electron-builder": "^24.13.3",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.0.1",
    "better-sqlite3": "^11.7.0",
    "electron-log": "^5.0.1",
    "electron-updater": "^6.8.3",
    "electron-window-state": "^5.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.0.0",
    "react-redux": "^9.0.4",
    "react-router-dom": "^6.21.1",
    "ssh2": "^1.16.0",
    "uuid": "^9.0.1",
    "zod": "^3.24.1"
  }
}
